# ==============================================
# 🔥 应用基础配置
# ==============================================
VITE_APP_NAME=ElectronEnterpriseTemplate
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
VITE_APP_DEBUG=true

# ==============================================
# 🔥 Hono 主进程服务端配置
# ==============================================
VITE_HONO_SERVER_HOST=127.0.0.1
VITE_HONO_SERVER_PORT=28619
VITE_HONO_CORS_ALLOWED_ORIGIN=http://localhost:28619
VITE_HONO_API_PREFIX=/api

# ==============================================
# 🔥 AI 配置 (OpenAI + Vercel AI SDK)
# ==============================================
VITE_AI_OPENAI_API_KEY=your-openai-api-key
VITE_AI_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_AI_OPENAI_MODEL=gpt-3.5-turbo
VITE_AI_ENABLED=true

# ==============================================
# 🔥 云存储 - 阿里云 OSS
# ==============================================
VITE_CLOUD_STORAGE_PLATFORM=aliyun
VITE_ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
VITE_ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
VITE_ALIYUN_OSS_BUCKET=your-bucket
VITE_ALIYUN_OSS_REGION=oss-cn-beijing
VITE_ALIYUN_OSS_DOMAIN=https://your-domain.oss-cn-beijing.aliyuncs.com

# ==============================================
# 🔥 云存储 - 腾讯云 COS
# ==============================================
VITE_TENCENT_COS_SECRET_ID=your-secret-id
VITE_TENCENT_COS_SECRET_KEY=your-secret-key
VITE_TENCENT_COS_BUCKET=your-bucket
VITE_TENCENT_COS_REGION=ap-beijing

# ==============================================
# 🔥 本地存储加密密钥（企业级必须）
# electron-store / lowdb / sqlite 加密通用
# ==============================================
VITE_STORAGE_ENCRYPTION_KEY=your-32-bit-encrypt-key-2025
VITE_STORAGE_DATA_PATH=./data

# ==============================================
# 🔥 高德地图 SDK（后续扩展）
# ==============================================
VITE_AMAP_WEB_KEY=your-amap-web-key
VITE_AMAP_SECURITY_KEY=your-amap-security-key
VITE_AMAP_ENABLED=false

# ==============================================
# 🔥 系统安全配置
# ==============================================
VITE_SECURITY_IPC_WHITELIST=ping,get-system-info,get-config,set-config,ai-chat
VITE_SECURITY_SANDBOX_ENABLED=true
VITE_SECURITY_CONTEXT_ISOLATION=true

# ==============================================
# 🔥 日志配置
# ==============================================
VITE_LOG_LEVEL=info
VITE_LOG_MAX_SIZE=5MB
VITE_LOG_MAX_FILES=5

# ==============================================
# 🔥 窗口默认配置
# ==============================================
VITE_WINDOW_DEFAULT_WIDTH=1000
VITE_WINDOW_DEFAULT_HEIGHT=700
VITE_WINDOW_MIN_WIDTH=800
VITE_WINDOW_MIN_HEIGHT=500
VITE_WINDOW_FRAMELESS=false
